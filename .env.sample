TYPE=foodsharing-cms

# Use the SAME domain as your Karrot app so the CMS is served same-origin at
# https://<domain>/fss-cms (Traefik routes the path; no Karrot changes needed).
DOMAIN=foodsharing.se

LETS_ENCRYPT_ENV=production

COMPOSE_FILE="compose.yml"

# Not needed when served same-origin (above). Set to your site origin only if
# you host the CMS on a different domain.
CORS_ORIGINS=*

# Seed initial page content on first deploy (when the data volume is empty).
SEED_ON_EMPTY=true

# The editor password, provided as a Docker secret (see README).
SECRET_CMS_TOKEN_VERSION=v1
