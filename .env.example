# The editor password. The plugin's admin UI sends this as a bearer token.
# Generate something long, e.g.:  openssl rand -hex 24
CMS_TOKEN=change-me

# Port the service listens on (reverse-proxied in front).
PORT=8787

# Cross-origin reads/writes. If you reverse-proxy the CMS under the SAME
# domain as Karrot, leave this as "*" (no cross-origin requests happen).
# Otherwise set it to your site origin, e.g. https://foodsharing.se
CORS_ORIGINS=*

# Optional: override where data/images live (defaults to ./data and ./uploads).
# DATA_DIR=/var/lib/foodsharing-cms/data
# UPLOADS_DIR=/var/lib/foodsharing-cms/uploads
